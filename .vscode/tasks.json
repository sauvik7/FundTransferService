{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "FundTransfer.API/FundTransfer.API.csproj"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "clean",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "clean",
        "FundTransfer.API/FundTransfer.API.csproj"
      ],
      "group": "build",
      "problemMatcher": [
        "$msCompile"
      ],
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "deep clean",
      "type": "shell",
      "command": "rm -rf */*/bin */*/obj */bin */obj && rm -rf **/TestResults **/coverage && rm -f FundTransfer.API/audit.log",
      "problemMatcher": [],
      "detail": "Removes build artifacts, test results, coverage, and logs"
    },
    {
      "label": "run tests",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "test",
        "FundTransfer.Tests/FundTransfer.Tests.csproj",
        "--no-restore"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "generate coverage",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "./scripts/generate-coverage.sh"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "presentation": {
        "reveal": "always"
      }
    }
  ]
}