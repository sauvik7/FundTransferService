{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Project",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "FundTransfer.API/FundTransfer.API.csproj"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "presentation": {
        "reveal": "always"
      },
      "detail": "Perform a standard build of the project, compiling source code and generating necessary artifacts for development and testing."
    },
    {
      "label": "Clean Project",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "clean",
        "FundTransfer.API/FundTransfer.API.csproj"
      ],
      "group": "build",
      "problemMatcher": [
        "$msCompile"
      ],
      "presentation": {
        "reveal": "always"
      },
      "detail": "Perform a standard clean of the project, removing build artifacts but keeping logs and test results."
    },
    {
      "label": "Deep Clean",
      "type": "shell",
      "command": "rm -rf **/bin **/obj **/TestResults **/coverage && rm -f FundTransfer.API/audit.log",
      "dependsOn": [
        "Clean Project"
      ],
      "problemMatcher": [],
      "detail": "Runs standard clean, then purges all bin/obj, test results, coverage directories, and logs."
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "test",
        "FundTransfer.Tests/FundTransfer.Tests.csproj",
        "--no-restore"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "presentation": {
        "reveal": "always"
      },
      "detail": "Run all unit tests in the project, using the latest build artifacts without restoring packages."
    },
    {
      "label": "Generate Coverage",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "./scripts/generate-coverage.sh"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "presentation": {
        "reveal": "always"
      },
      "detail": "Generate code coverage reports for the project."
    }
  ]
}